# ============================================================
#  Route Resilience AI — Environment Configuration
#  Copy this file to .env and fill in your values
# ============================================================

# ── App ──────────────────────────────────────────────────────
APP_NAME="Route Resilience AI"
APP_ENV=development          # development | production
DEBUG=true
SECRET_KEY=change-me-to-a-random-secret

# ── Server ───────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
FRONTEND_ORIGIN=http://localhost:5173

# ── Database (SQLite for dev) ─────────────────────────────────
DATABASE_URL=sqlite:///./reroute.db
# For production with PostGIS:
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/reroute

# ── Redis (optional cache) ────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
USE_REDIS=false              # set true when Redis is running

# ── Google Earth Engine ───────────────────────────────────────
# Your Google Cloud project that has Earth Engine API enabled
# Project Number : 505190856684
# Project ID     : gen-lang-client-0065697514
GEE_PROJECT_ID=gen-lang-client-0065697514

# Option A: Service Account (production / server)
GEE_SERVICE_ACCOUNT_EMAIL=your-service-account@gen-lang-client-0065697514.iam.gserviceaccount.com
GEE_SERVICE_ACCOUNT_KEY_PATH=gee-service-account.json

# Option B: OAuth (local dev — leave email blank to trigger browser auth)
# GEE_SERVICE_ACCOUNT_EMAIL=

# ── Default AOI: Coimbatore, Tamil Nadu ───────────────────────
DEFAULT_CITY=Coimbatore
DEFAULT_LAT=11.0168
DEFAULT_LON=76.9558
DEFAULT_RADIUS_KM=15

# GEE bounding box [lon_min, lat_min, lon_max, lat_max]
DEFAULT_BBOX_XMIN=76.85
DEFAULT_BBOX_YMIN=10.90
DEFAULT_BBOX_XMAX=77.10
DEFAULT_BBOX_YMAX=11.15

# ── Satellite / GEE ──────────────────────────────────────────
GEE_COLLECTION=COPERNICUS/S2_SR_HARMONIZED   # Sentinel-2 Surface Reflectance
GEE_CLOUD_THRESHOLD=20                        # % cloud cover max
GEE_DEFAULT_START=2024-01-01
GEE_DEFAULT_END=2024-12-31
GEE_SCALE_METERS=10                           # Sentinel-2 native res

# ── AI Model ──────────────────────────────────────────────────
MODEL_WEIGHTS_PATH=ai/weights/best_model.pth
MODEL_DEVICE=cpu              # cpu | cuda | mps
INFERENCE_TILE_SIZE=512       # sliding window tile size
INFERENCE_OVERLAP=64          # overlap between tiles

# ── AWS (for SpaceNet download) ───────────────────────────────
AWS_DEFAULT_REGION=us-east-1
# AWS_ACCESS_KEY_ID and AWS_SECRET_ACCESS_KEY are read from AWS CLI config

# ── SpaceNet ─────────────────────────────────────────────────
SPACENET_S3_BUCKET=spacenet-dataset
SPACENET_DATASET=spacenet-roads-v2
SPACENET_LOCAL_DIR=ai/datasets/raw

# ── Colab Integration ─────────────────────────────────────────
GDRIVE_WEIGHTS_PATH=/content/drive/MyDrive/reroute-ai/weights
